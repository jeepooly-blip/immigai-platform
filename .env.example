# ─────────────────────────────────────────────────────────────
# ImmigAI Platform — Environment Variables
# Copy this file to .env.local and fill in all values
# ─────────────────────────────────────────────────────────────

# DATABASE (PostgreSQL — https://neon.tech or https://supabase.com)
DATABASE_URL="postgresql://user:password@host:5432/immigai?sslmode=require"
DIRECT_URL="postgresql://user:password@host:5432/immigai?sslmode=require"

# NEXTAUTH
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# ANTHROPIC AI
ANTHROPIC_API_KEY="sk-ant-..."

# STRIPE PAYMENTS
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_PRO_PRICE_ID="price_..."
STRIPE_ENTERPRISE_PRICE_ID="price_..."

# FILE STORAGE — set to "s3" to use AWS S3 instead of Vercel Blob
STORAGE_PROVIDER="blob"  # "blob" | "s3"

# FILE STORAGE — Vercel Blob (primary) or AWS S3 (optional)
BLOB_READ_WRITE_TOKEN="vercel_blob_..."

# AWS S3 (optional, for larger files / on-premise)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_S3_BUCKET=""

# EMAIL — Resend (https://resend.com)
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@yourfirm.com"

# APP
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_DEMO_MODE="false"

# CRON (for regulatory alert fetching)
CRON_SECRET="generate-with-openssl-rand-hex-32"

# FEATURE FLAGS
NEXT_PUBLIC_ENABLE_INTERVIEW_PREP="true"
NEXT_PUBLIC_ENABLE_HR_MODULE="false"
NEXT_PUBLIC_ENABLE_GEO_GATES="true"
